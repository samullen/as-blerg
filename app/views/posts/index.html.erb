<% content_for :title, "Posts" %>

<div class="flex items-center justify-between mb-8">
  <h1 class="text-3xl font-bold">Posts</h1>
</div>

<% if @posts.any? %>
  <div class="flex flex-col gap-4" id="posts">
    <% @posts.each do |post| %>
      <%= render post %>
    <% end %>
  </div>
<% else %>
  <div class="card bg-base-100 shadow-sm">
    <div class="card-body items-center text-center py-16">
      <p class="text-base-content/50 text-lg">No posts yet.</p>
      <p class="text-base-content/40 text-sm mt-1">Select a writer below to publish the first one.</p>
      <%= link_to "Browse Writers", users_path, class: "btn btn-primary mt-4" %>
    </div>
  </div>
<% end %>
