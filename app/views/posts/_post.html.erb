<div id="<%= dom_id post %>" class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow">
  <div class="card-body">
    <div class="flex items-start justify-between gap-4">
      <div class="flex-1 min-w-0">
        <h2 class="card-title text-xl">
          <%= link_to post.title, post, class: "hover:text-primary transition-colors" %>
        </h2>
        <p class="text-base-content/60 text-sm mt-1">
          by <span class="font-medium"><%= post.user.username %></span>
          &middot;
          <%= post.created_at.strftime("%B %-d, %Y") %>
        </p>
      </div>
      <div class="flex gap-2 shrink-0">
        <%= link_to "Edit", edit_post_path(post), class: "btn btn-ghost btn-xs" %>
        <%= button_to "Delete", post, method: :delete,
              class: "btn btn-ghost btn-xs text-error",
              form: { data: { turbo_confirm: "Delete this post?" } } %>
      </div>
    </div>
    <p class="text-base-content/70 mt-2 line-clamp-3"><%= post.content %></p>
    <div class="card-actions justify-end mt-2">
      <%= link_to "Read more →", post, class: "link link-primary text-sm" %>
    </div>
  </div>
</div>
