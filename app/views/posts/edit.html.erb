</div>

<div class="card bg-base-100 shadow-sm max-w-2xl mx-auto">
  <div class="card-body">
    <h1 class="card-title text-2xl mb-4">Edit Post</h1>
    <%= render "form", post: @post %>
  </div>
</div>
