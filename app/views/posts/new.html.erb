<% content_for :title, "New post" %>

<div class="mb-4">
  <%= link_to "← Back to posts", posts_path, class: "link link-hover text-sm text-base-content/60" %>
</div>

<div class="card bg-base-100 shadow-sm max-w-2xl mx-auto">
  <div class="card-body">
    <h1 class="card-title text-2xl mb-4">New Post</h1>
    <p class="text-base-content/60 text-sm mb-6">
      Writing as <span class="font-semibold"><%= @user.username %></span>
    </p>
    <%= render "form", post: @post, user: @user %>
  </div>
</div>
